/* 马卡龙治愈风 - 反馈页 */
.feedback-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #FFF5F9 0%, #F8FEFF 40%, #ffffff 100%);
  position: relative;
}

.feedback-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 400rpx;
  background: linear-gradient(135deg, rgba(246, 198, 234, 0.2) 0%, rgba(181, 232, 224, 0.2) 100%);
  border-radius: 0 0 50% 50% / 0 0 30% 30%;
}

.feedback-content {
  position: relative;
  padding: 48rpx 40rpx 80rpx;
}

.feedback-header {
  text-align: center;
  margin-bottom: 48rpx;
}

.feedback-icon {
  width: 120rpx;
  height: 120rpx;
  margin: 0 auto 24rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, rgba(246, 198, 234, 0.4) 0%, rgba(181, 232, 224, 0.4) 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 56rpx;
}

.feedback-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #0F172A;
  display: block;
  margin-bottom: 16rpx;
}

.feedback-desc {
  font-size: 28rpx;
  color: #64748B;
  line-height: 1.6;
}

.feedback-form {
  background: #fff;
  border-radius: 32rpx;
  padding: 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(246, 198, 234, 0.15);
  border: 2rpx solid rgba(246, 198, 234, 0.2);
  margin-bottom: 48rpx;
}

.feedback-input {
  width: 100%;
  min-height: 320rpx;
  font-size: 32rpx;
  color: #0F172A;
  line-height: 1.6;
  box-sizing: border-box;
}

.feedback-placeholder {
  color: #94A3B8;
}

.feedback-count {
  font-size: 26rpx;
  color: #94A3B8;
  text-align: right;
  display: block;
  margin-top: 12rpx;
}

.feedback-btn-wrap {
  padding: 0 16rpx;
}

.feedback-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  font-size: 34rpx;
  font-weight: 600;
  color: #fff;
  background: linear-gradient(135deg, #F6C6EA 0%, #B5E8E0 100%);
  border-radius: 48rpx;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(181, 232, 224, 0.4);
}

.feedback-btn::after {
  border: none;
}

.feedback-btn.disabled {
  opacity: 0.5;
}
