<view class="page">
  <!-- ===== Top Section ===== -->
  <view class="top-section">
    <view style="height: {{statusBarHeight}}px;"></view>

    <!-- Header：家庭管理(左) + 反馈(右) -->
    <view class="header" style="padding-right: {{headerRightPadding || 96}}rpx;">
      <view class="header-left">
        <view class="header-btn" bindtap="onMenuClick">
          <view class="menu-line"></view>
          <view class="menu-line"></view>
          <view class="menu-line"></view>
        </view>
        <view class="cs-icon-wrap" bindtap="onFeedbackTap">
          <text class="cs-icon">🎧</text>
        </view>
      </view>
    </view>

    <!-- Title & Clear Expired -->
    <view class="title-row">
      <text class="page-title">冰箱物品</text>
      <view class="clear-expired-btn" bindtap="onClearExpired">清除过期物品</view>
    </view>

    <!-- Family Bar -->
    <view wx:if="{{currentGroup}}" class="group-bar" bindtap="onSwitchGroup">
      <text class="group-bar-name">{{currentGroup.name}}</text>
      <text class="group-bar-arrow">▾</text>
    </view>

    <!-- Type Tabs -->
    <view wx:if="{{currentGroup}}" class="type-tabs">
      <view wx:for="{{typeTabs}}" wx:key="*this" class="type-tab {{selectedTypeTab === item ? 'active' : ''}}"
            bindtap="onSelectTypeTab" data-tab="{{item}}">{{item}}</view>
    </view>

    <!-- Search Bar -->
    <view wx:if="{{currentGroup}}" class="search-bar">
      <view class="search-inner">
        <text class="search-icon">🔍</text>
        <input class="search-input" placeholder="搜索物品名称、备注"
               value="{{searchKeyword}}" bindinput="onSearchInput" />
        <text wx:if="{{searchKeyword}}" class="search-clear" bindtap="onClearSearch">✕</text>
      </view>
    </view>
  </view>

  <!-- ===== Item List ===== -->
  <scroll-view scroll-y class="item-scroll" style="height: {{listHeight}}px;">
    <view class="item-list">
      <view wx:if="{{items.length === 0}}" class="empty-state" bindtap="onAddItem">
        <view class="empty-icon">🧊</view>
        <text class="empty-text">暂无物品</text>
        <text class="empty-hint">点击添加冰箱物品</text>
      </view>
      <view wx:elif="{{displayItems.length === 0}}" class="empty-state search-empty">
        <view class="empty-icon">🔍</view>
        <text class="empty-text">未找到「{{searchKeyword}}」相关物品</text>
        <text class="empty-hint" bindtap="onClearSearch">点击清除搜索</text>
      </view>
      <view wx:for="{{displayItems}}" wx:key="id" class="item-card {{item.urgency}}"
            bindtap="onItemClick" data-id="{{item.id}}">
        <view class="item-main">
          <text class="item-name">{{item.title}}</text>
          <view class="item-meta-row">
            <text class="item-type-tag">{{item.type || '冷藏'}}</text>
            <text class="item-expiry-text {{item.urgency}}">
              <text wx:if="{{item.daysLeft > 0}}">{{item.daysLeft}}天</text>
              <text wx:elif="{{item.daysLeft === 0}}">今天</text>
              <text wx:else>过期</text>
            </text>
          </view>
          <text wx:if="{{item.note}}" class="item-note">{{item.note}}</text>
        </view>
        <view class="item-delete-btn" catchtap="onQuickDelete" data-id="{{item.id}}">
          <text class="item-delete-icon">🗑</text>
        </view>
      </view>
    </view>
  </scroll-view>

  <!-- ===== Add FAB ===== -->
  <view class="add-fab" bindtap="onAddItem">
    <text class="add-fab-icon">+</text>
  </view>

  <!-- ===== Bell FAB (notification auth) ===== -->
  <view class="bell-fab" bindtap="onBellTap">
    <text class="bell-icon">🔔</text>
  </view>

  <!-- ===== Family Gate (no family) ===== -->
  <view wx:if="{{groupGateVisible}}" class="modal-overlay show" style="z-index: 220; justify-content: center; align-items: center;">
    <view class="group-gate" catchtap="noop">
      <text class="group-gate-title">选择操作</text>
      <view class="group-gate-btns">
        <view class="group-gate-btn primary" bindtap="onShowCreateGroup">
          <text>创建家庭</text>
          <text class="group-gate-desc">新建一个家庭，邀请家人加入</text>
        </view>
        <view class="group-gate-btn" bindtap="onShowJoinGroup">
          <text>加入家庭</text>
          <text class="group-gate-desc">输入邀请码加入已有家庭</text>
        </view>
      </view>
    </view>
  </view>

  <!-- ===== Create Family ===== -->
  <view wx:if="{{createGroupVisible}}" class="modal-overlay show" style="z-index: 230; justify-content: center; align-items: center;" bindtap="closeCreateGroup">
    <view class="group-form" catchtap="noop">
      <text class="group-form-title">创建家庭</text>
      <input class="group-form-input" value="{{newGroupName}}" bindinput="onNewGroupNameInput" placeholder="例如：小明的家庭" />
      <view class="group-form-btns">
        <button class="group-form-cancel" bindtap="closeCreateGroup">取消</button>
        <button class="group-form-confirm" bindtap="onCreateGroup">创建</button>
      </view>
    </view>
  </view>

  <!-- ===== Join Family ===== -->
  <view wx:if="{{joinGroupVisible}}" class="modal-overlay show" style="z-index: 230; justify-content: center; align-items: center;" bindtap="closeJoinGroup">
    <view class="group-form" catchtap="noop">
      <text class="group-form-title">加入家庭</text>
      <input class="group-form-input" value="{{joinInviteCode}}" bindinput="onJoinCodeInput" placeholder="输入6位邀请码" maxlength="6" />
      <view class="group-form-btns">
        <button class="group-form-cancel" bindtap="closeJoinGroup">取消</button>
        <button class="group-form-confirm" bindtap="onJoinGroup">加入</button>
      </view>
    </view>
  </view>

  <!-- ===== Join Success Modal ===== -->
  <view wx:if="{{joinSuccessVisible}}" class="modal-overlay show" style="z-index: 240; justify-content: center; align-items: center;" bindtap="closeJoinSuccess">
    <view class="join-success-card" catchtap="noop">
      <view class="join-success-icon">✓</view>
      <text class="join-success-title">成功加入家庭</text>
      <text class="join-success-group">{{joinSuccessGroupName}}</text>
      <text class="join-success-desc" wx:if="{{joinSuccessViaLink}}">你已通过邀请链接加入该家庭，可以与家人一起查看和编辑冰箱物品啦～</text>
      <text class="join-success-desc" wx:else>你已通过邀请码加入该家庭，可以与家人一起查看和编辑冰箱物品啦～</text>
      <view class="join-success-tips">
        <text>• 邀请码与链接可在家庭成员管理中分享给家人</text>
      </view>
      <view class="join-success-btn" bindtap="closeJoinSuccess">知道了</view>
    </view>
  </view>

  <!-- ===== Family Switcher ===== -->
  <view wx:if="{{groupSwitcherVisible}}" class="modal-overlay show" style="z-index: 210; justify-content: center; align-items: center;" bindtap="closeGroupSwitcher">
    <view class="group-switcher" catchtap="noop">
      <text class="group-switcher-title">切换家庭</text>
      <view class="group-switcher-list">
        <view wx:for="{{myGroups}}" wx:key="_id" class="group-switcher-item {{item._id === currentGroupId ? 'active' : ''}}"
              bindtap="onSelectGroup" data-id="{{item._id}}">
          <text>{{item.name}}</text>
          <text wx:if="{{item._id === currentGroupId}}" class="group-switcher-check">✓</text>
        </view>
      </view>
      <view class="group-switcher-new" bindtap="onShowCreateGroup">
        <text class="group-switcher-new-icon">+</text>
        <text>创建新家庭</text>
      </view>
      <view class="group-switcher-new join" bindtap="onShowJoinGroup">
        <text class="group-switcher-new-icon">↗</text>
        <text>加入别人的家庭</text>
      </view>
    </view>
  </view>

  <!-- ===== Item Modal (创建/编辑物品) ===== -->
  <view wx:if="{{modalVisible}}" class="modal-overlay {{modalAnimating ? 'show' : ''}}" bindtap="closeItemModal">
    <view class="modal-sheet {{modalAnimating ? 'show' : ''}}" catchtap="noop">
      <view class="modal-handle"><view class="handle-bar"></view></view>
      <view class="modal-content">
        <view class="modal-header">
          <text class="modal-title">{{editingItem ? '编辑物品' : '添加物品'}}</text>
          <view class="close-btn" bindtap="closeItemModal"><text>✕</text></view>
        </view>
        <view class="form-group">
          <text class="form-label">物品名称</text>
          <input class="form-input"
                 value="{{itemName}}"
                 bindinput="onItemNameInput"
                 placeholder="例如：牛奶、酸奶、鸡蛋"
                 maxlength="50" />
        </view>
        <view class="form-group">
          <text class="form-label">类型</text>
          <view class="type-quick-row">
            <view wx:for="{{['冷藏','冷鲜','冷冻']}}" wx:key="*this" class="type-quick-btn {{itemType === item ? 'active' : ''}}"
                  bindtap="onTypeQuick" data-type="{{item}}">{{item}}</view>
          </view>
        </view>
        <view class="form-group">
          <text class="form-label">倒计时（几天后到期）</text>
          <input class="form-input countdown-input" type="number"
                 value="{{countdownDays}}"
                 bindinput="onCountdownInput"
                 placeholder="输入天数"
                 maxlength="3" />
          <view class="countdown-quick">
            <view wx:for="{{countdownQuicks}}" wx:key="*this" class="countdown-btn"
                  bindtap="onCountdownQuick" data-days="{{item}}">{{item}}</view>
          </view>
        </view>
        <view class="form-group">
          <text class="form-label">备注</text>
          <textarea class="form-textarea"
                    value="{{itemNote}}"
                    bindinput="onItemNoteInput"
                    placeholder="可选，如存放位置、购买渠道等"
                    maxlength="200"
                    auto-height />
        </view>
        <view class="form-actions">
          <button class="btn-primary {{!nameValid ? 'disabled' : ''}}"
                  bindtap="onSaveItem" disabled="{{!nameValid}}">
            {{editingItem ? '保存修改' : '添加物品'}} →
          </button>
          <button wx:if="{{editingItem}}" class="btn-danger" bindtap="onDeleteItem">
            删除物品
          </button>
        </view>
      </view>
    </view>
  </view>

  <!-- ===== Family Member Modal ===== -->
  <view wx:if="{{memberVisible}}" class="modal-overlay {{memberAnimating ? 'show' : ''}}" bindtap="closeMemberModal">
    <view class="modal-sheet {{memberAnimating ? 'show' : ''}}" catchtap="noop">
      <view class="modal-handle"><view class="handle-bar"></view></view>
      <view class="modal-content">
        <view class="modal-header">
          <text class="modal-title">家庭成员管理</text>
          <view class="close-btn" bindtap="closeMemberModal"><text>✕</text></view>
        </view>
        <view wx:if="{{currentGroup}}" class="member-invite-inline">
          <view class="member-invite-row">
            <text>邀请码 {{currentGroup.inviteCode}}</text>
            <text class="member-invite-copy" bindtap="onCopyInviteCode">复制</text>
            <text class="member-invite-sep">|</text>
            <text class="member-invite-link" bindtap="onGenerateInviteLink">生成链接</text>
          </view>
          <text class="member-invite-tip">新成员需通过邀请码或邀请链接加入</text>
        </view>

        <scroll-view scroll-y style="max-height: 400rpx;" class="member-list">
          <view wx:for="{{members}}" wx:key="id" class="member-item">
            <view class="member-avatar member-avatar-fullname"
                  style="background: {{item.color.bg}}; border-color: #fff;">
              <text>{{item.name}}</text>
            </view>
            <view class="member-info">
              <view class="member-name-row">
                <text class="member-name">{{item.name}}</text>
                <text wx:if="{{item.role === 'creator'}}" class="creator-tag">创建者</text>
              </view>
            </view>
            <view wx:if="{{myRole === 'creator' && !item.isMe && item.role !== 'creator'}}" class="member-remove-btn" catchtap="onRemoveMember" data-openid="{{item.openid}}" data-name="{{item.name}}">
              <text>移出</text>
            </view>
          </view>
        </scroll-view>

        <view wx:if="{{myRole !== 'creator' && currentGroup}}" class="member-leave-row" bindtap="onLeaveGroup">
          <text class="member-leave-text">退出该家庭</text>
        </view>
        <view wx:if="{{myRole === 'creator' && currentGroup}}" class="member-delete-row" bindtap="onDeleteGroup">
          <text class="member-delete-text">删除该家庭</text>
        </view>
      </view>
    </view>
  </view>

  <!-- ===== 意见反馈弹窗（点击即开，无跳转延迟）===== -->
  <view wx:if="{{feedbackVisible}}" class="modal-overlay {{feedbackAnimating ? 'show' : ''}}" bindtap="closeFeedbackModal">
    <view class="feedback-modal {{feedbackAnimating ? 'show' : ''}}" catchtap="noop">
      <view class="modal-handle"><view class="handle-bar"></view></view>
      <view class="feedback-modal-header">
        <text class="feedback-modal-title">意见反馈</text>
        <view class="close-btn" bindtap="closeFeedbackModal"><text>✕</text></view>
      </view>
      <text class="feedback-modal-desc">欢迎留下您的宝贵建议～</text>
      <view class="feedback-modal-input-wrap">
        <textarea class="feedback-modal-input"
          placeholder="请输入您的反馈内容..."
          placeholder-class="feedback-modal-placeholder"
          value="{{feedbackText}}"
          bindinput="onFeedbackInput"
          maxlength="500" />
        <text class="feedback-modal-count">{{feedbackText.length}}/500</text>
      </view>
      <view class="feedback-modal-actions">
        <button class="feedback-modal-btn {{!feedbackCanSubmit ? 'disabled' : ''}}"
          bindtap="onFeedbackSubmit"
          disabled="{{!feedbackCanSubmit}}">确认提交</button>
        <text class="contact-admin" catchtap="onCopyWechat">联系管理员</text>
      </view>
    </view>
  </view>

  <!-- 自定义 Toast -->
  <view wx:if="{{toastVisible}}" class="custom-toast">
    <text class="custom-toast-icon">✓</text>
    <text class="custom-toast-text">{{toastText}}</text>
  </view>
</view>
